# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS commiter le fichier .env sur Git

# Base de données MySQL
DB_URL=jdbc:mysql://localhost:3306/mdd_db?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=votre_mot_de_passe

# JWT — générer une clé aléatoire sécurisée (min. 64 caractères hex)
JWT_SECRET=votre_secret_jwt_ici
JWT_EXPIRATION=86400000

